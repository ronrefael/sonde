{
  "name": "sonde",
  "displayName": "sonde — AI Usage Monitor",
  "description": "Real-time AI usage monitoring in VS Code status bar",
  "version": "0.1.0",
  "publisher": "ronrefael",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sonde.showDashboard",
        "title": "Sonde: Show Dashboard"
      },
      {
        "command": "sonde.refresh",
        "title": "Sonde: Refresh"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
